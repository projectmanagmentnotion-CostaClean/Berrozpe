---
import type { Locale } from '../lib/content';
import { buildWhatsAppUrl, getWhatsAppContent } from '../lib/content';

interface Props {
  locale: Locale;
  variant?: 'floating' | 'inline' | 'large';
  message?: string;
  className?: string;
  labelMode?: 'full' | 'short';
}

const { locale, variant = 'inline', message, className = '', labelMode = 'full' } = Astro.props;
const content = getWhatsAppContent(locale);
const href = buildWhatsAppUrl(locale, message);
const buttonLabel = labelMode === 'short' ? content.shortLabel : content.label;
---

{variant === 'floating' && (
  <>
    <a
      href={href}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={content.ariaLabel}
      class:list={[
        'berrozpe-whatsapp-floating group fixed right-4 z-30 inline-flex min-h-12 items-center gap-2 rounded-full border border-[#25D366] bg-[#25D366] px-3 py-2.5 text-sm font-semibold text-white shadow-[0_20px_45px_rgba(37,211,102,0.28)] transition hover:border-[#1ebe5b] hover:bg-[#1ebe5b] sm:right-5 sm:min-h-14 sm:gap-3 sm:px-5 sm:py-3',
        className,
      ]}
      data-whatsapp-floating
    >
      <span class="flex h-8 w-8 items-center justify-center rounded-full bg-white/18 sm:h-9 sm:w-9" aria-hidden="true">
        <svg viewBox="0 0 24 24" class="h-4 w-4 fill-current sm:h-5 sm:w-5" aria-hidden="true">
          <path d="M20.52 3.48A11.86 11.86 0 0 0 12.06 0C5.5 0 .16 5.33.16 11.89c0 2.1.55 4.16 1.6 5.97L0 24l6.33-1.66a11.83 11.83 0 0 0 5.73 1.47h.01c6.55 0 11.89-5.34 11.89-11.9 0-3.17-1.23-6.15-3.44-8.43Zm-8.46 18.3h-.01a9.83 9.83 0 0 1-5-1.37l-.36-.21-3.76.99 1-3.66-.24-.38a9.84 9.84 0 0 1-1.51-5.27c0-5.45 4.44-9.89 9.9-9.89 2.64 0 5.12 1.03 6.98 2.9a9.82 9.82 0 0 1 2.9 6.99c0 5.46-4.44 9.9-9.9 9.9Zm5.43-7.42c-.3-.15-1.77-.87-2.04-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.95 1.17-.17.2-.35.22-.65.07-.3-.15-1.25-.46-2.38-1.46-.88-.79-1.47-1.76-1.65-2.06-.17-.3-.02-.46.13-.61.14-.14.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.62-.92-2.22-.24-.58-.49-.5-.67-.5h-.57c-.2 0-.52.08-.8.37-.27.3-1.05 1.02-1.05 2.5 0 1.47 1.08 2.9 1.22 3.1.15.2 2.12 3.24 5.14 4.54.72.31 1.29.5 1.72.64.72.23 1.37.2 1.89.12.58-.09 1.77-.72 2.02-1.42.25-.69.25-1.29.17-1.42-.07-.13-.27-.2-.57-.35Z" />
        </svg>
      </span>
      <span class="hidden sm:inline">{content.floatingText}</span>
    </a>
    <script is:inline>
      const consentSelector = '[data-cookie-consent-root]';
      const floatingSelector = '[data-whatsapp-floating]';
      const defaultOffset = 16;

      const syncWhatsAppOffset = () => {
        const floating = document.querySelector(floatingSelector);
        if (!(floating instanceof HTMLElement)) return;

        const consent = document.querySelector(consentSelector);
        let offset = defaultOffset;

        if (consent instanceof HTMLElement && !consent.hasAttribute('hidden')) {
          const styles = window.getComputedStyle(consent);
          if (styles.display !== 'none' && styles.visibility !== 'hidden') {
            offset += consent.getBoundingClientRect().height + 12;
          }
        }

        floating.style.bottom = `${offset}px`;
      };

      const bootWhatsAppFloating = () => {
        syncWhatsAppOffset();
        const consent = document.querySelector(consentSelector);
        if (consent instanceof HTMLElement) {
          const observer = new MutationObserver(syncWhatsAppOffset);
          observer.observe(consent, { attributes: true, childList: true, subtree: true });
          window.addEventListener('resize', syncWhatsAppOffset, { passive: true });
        }
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', bootWhatsAppFloating, { once: true });
      } else {
        bootWhatsAppFloating();
      }
    </script>
  </>
)}

{variant === 'inline' && (
  <a
    href={href}
    target="_blank"
    rel="noopener noreferrer"
    aria-label={content.ariaLabel}
    class:list={[
      'inline-flex min-h-11 items-center justify-center gap-2 rounded-full border border-[#25D366] bg-[#25D366] px-5 py-3 text-sm font-medium text-white transition hover:border-[#1ebe5b] hover:bg-[#1ebe5b] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#25D366] focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--color-bg)]',
      className,
    ]}
  >
    <svg viewBox="0 0 24 24" class="h-4 w-4 fill-current" aria-hidden="true">
      <path d="M20.52 3.48A11.86 11.86 0 0 0 12.06 0C5.5 0 .16 5.33.16 11.89c0 2.1.55 4.16 1.6 5.97L0 24l6.33-1.66a11.83 11.83 0 0 0 5.73 1.47h.01c6.55 0 11.89-5.34 11.89-11.9 0-3.17-1.23-6.15-3.44-8.43Zm-8.46 18.3h-.01a9.83 9.83 0 0 1-5-1.37l-.36-.21-3.76.99 1-3.66-.24-.38a9.84 9.84 0 0 1-1.51-5.27c0-5.45 4.44-9.89 9.9-9.89 2.64 0 5.12 1.03 6.98 2.9a9.82 9.82 0 0 1 2.9 6.99c0 5.46-4.44 9.9-9.9 9.9Zm5.43-7.42c-.3-.15-1.77-.87-2.04-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.95 1.17-.17.2-.35.22-.65.07-.3-.15-1.25-.46-2.38-1.46-.88-.79-1.47-1.76-1.65-2.06-.17-.3-.02-.46.13-.61.14-.14.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.62-.92-2.22-.24-.58-.49-.5-.67-.5h-.57c-.2 0-.52.08-.8.37-.27.3-1.05 1.02-1.05 2.5 0 1.47 1.08 2.9 1.22 3.1.15.2 2.12 3.24 5.14 4.54.72.31 1.29.5 1.72.64.72.23 1.37.2 1.89.12.58-.09 1.77-.72 2.02-1.42.25-.69.25-1.29.17-1.42-.07-.13-.27-.2-.57-.35Z" />
    </svg>
    <span>{buttonLabel}</span>
  </a>
)}

{variant === 'large' && (
  <article class:list={['rounded-[2rem] border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-5 sm:p-6', className]}>
    <p class="text-[0.72rem] uppercase tracking-[0.22em] text-[var(--color-text-soft)]">{content.shortLabel}</p>
    <h2 class="mt-3 font-[var(--font-display)] text-2xl font-semibold tracking-[-0.03em] text-[var(--color-text)] sm:text-3xl">
      {content.sectionTitle}
    </h2>
    <p class="mt-3 max-w-2xl text-base leading-7 text-[var(--color-text-muted)]">{content.sectionDescription}</p>
    <div class="mt-5 flex flex-wrap gap-3">
      <a
        href={href}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={content.ariaLabel}
        class="inline-flex min-h-12 items-center justify-center gap-2 rounded-full border border-[#25D366] bg-[#25D366] px-6 py-3.5 text-sm font-medium text-white transition hover:border-[#1ebe5b] hover:bg-[#1ebe5b] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#25D366] focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--color-bg)] sm:text-base"
      >
        <svg viewBox="0 0 24 24" class="h-5 w-5 fill-current" aria-hidden="true">
          <path d="M20.52 3.48A11.86 11.86 0 0 0 12.06 0C5.5 0 .16 5.33.16 11.89c0 2.1.55 4.16 1.6 5.97L0 24l6.33-1.66a11.83 11.83 0 0 0 5.73 1.47h.01c6.55 0 11.89-5.34 11.89-11.9 0-3.17-1.23-6.15-3.44-8.43Zm-8.46 18.3h-.01a9.83 9.83 0 0 1-5-1.37l-.36-.21-3.76.99 1-3.66-.24-.38a9.84 9.84 0 0 1-1.51-5.27c0-5.45 4.44-9.89 9.9-9.89 2.64 0 5.12 1.03 6.98 2.9a9.82 9.82 0 0 1 2.9 6.99c0 5.46-4.44 9.9-9.9 9.9Zm5.43-7.42c-.3-.15-1.77-.87-2.04-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.95 1.17-.17.2-.35.22-.65.07-.3-.15-1.25-.46-2.38-1.46-.88-.79-1.47-1.76-1.65-2.06-.17-.3-.02-.46.13-.61.14-.14.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.62-.92-2.22-.24-.58-.49-.5-.67-.5h-.57c-.2 0-.52.08-.8.37-.27.3-1.05 1.02-1.05 2.5 0 1.47 1.08 2.9 1.22 3.1.15.2 2.12 3.24 5.14 4.54.72.31 1.29.5 1.72.64.72.23 1.37.2 1.89.12.58-.09 1.77-.72 2.02-1.42.25-.69.25-1.29.17-1.42-.07-.13-.27-.2-.57-.35Z" />
        </svg>
        <span>{content.label}</span>
      </a>
    </div>
  </article>
)}
