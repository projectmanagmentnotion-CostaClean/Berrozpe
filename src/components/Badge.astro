---
interface Props {
  text: string;
  className?: string;
}

const { text, className = '' } = Astro.props;
---

<span class:list={['inline-flex items-center rounded-full border border-[var(--color-border)] bg-white/[0.03] px-3 py-1 text-[0.7rem] font-medium uppercase tracking-[0.22em] text-[var(--color-text-soft)]', className]}>
  {text}
</span>
