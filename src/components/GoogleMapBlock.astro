---
import type { MapContent } from '../data/types';
import type { Locale } from '../lib/content';
import { getMapContent, getSharedContact } from '../lib/content';
import Button from './Button.astro';
import Card from './Card.astro';

interface Props {
  locale: Locale;
  variant?: 'full' | 'compact' | 'footer';
  showLiveMap?: boolean;
  mapUrl?: string;
  embedUrl?: string | null;
  address?: string | string[];
  content?: Partial<MapContent>;
  className?: string;
}

const {
  locale,
  variant = 'full',
  showLiveMap = false,
  mapUrl,
  embedUrl = null,
  address,
  content: contentOverride,
  className = '',
} = Astro.props;

const sharedContact = getSharedContact();
const baseContent = getMapContent(locale);
const content = { ...baseContent, ...contentOverride } satisfies MapContent;
const resolvedMapUrl = mapUrl ?? sharedContact.googleMapsUrl ?? '#';
const resolvedAddress = Array.isArray(address)
  ? address
  : typeof address === 'string'
    ? [address]
    : sharedContact.address.displayLines;
const canLoadLiveMap = Boolean(showLiveMap && embedUrl);
---

{variant === 'footer' && (
  <a
    href={resolvedMapUrl}
    target="_blank"
    rel="noopener noreferrer"
    class:list={[
      'inline-flex min-h-11 items-center justify-center rounded-full border border-[var(--color-border)] px-5 py-3 text-sm font-medium text-[var(--color-text)] transition hover:border-[var(--color-border-strong)] hover:bg-white/5',
      className,
    ]}
  >
    {content.footerLinkLabel}
  </a>
)}

{variant === 'compact' && (
  <Card className={className}>
    <div class="space-y-3">
      <p class="text-[0.72rem] uppercase tracking-[0.22em] text-[var(--color-text-soft)]">{content.subtitle}</p>
      <h2 class="font-[var(--font-display)] text-2xl font-semibold tracking-[-0.03em] text-[var(--color-text)]">
        {content.title}
      </h2>
      <p class="text-base leading-7 text-[var(--color-text-muted)]">{content.description}</p>
    </div>
    <div class="mt-5 rounded-[1.5rem] border border-[var(--color-border)] bg-white/60 p-4">
      <p class="text-[0.72rem] uppercase tracking-[0.22em] text-[var(--color-text-soft)]">{content.addressLabel}</p>
      <div class="mt-3 space-y-1 text-base leading-7 text-[var(--color-text)]">
        {resolvedAddress.map((line) => <p>{line}</p>)}
      </div>
    </div>
    <p class="mt-4 text-sm leading-6 text-[var(--color-text-soft)]">{content.fallbackText}</p>
    <div class="mt-6">
      <Button href={resolvedMapUrl} variant="secondary" target="_blank" rel="noopener noreferrer">
        {content.openMapLabel}
      </Button>
    </div>
  </Card>
)}

{variant === 'full' && (
  <Card className={className}>
    <div class="space-y-3">
      <p class="text-[0.72rem] uppercase tracking-[0.22em] text-[var(--color-text-soft)]">{content.subtitle}</p>
      <h2 class="font-[var(--font-display)] text-2xl font-semibold tracking-[-0.03em] text-[var(--color-text)] sm:text-3xl">
        {content.title}
      </h2>
      <p class="max-w-2xl text-base leading-7 text-[var(--color-text-muted)]">{content.description}</p>
    </div>

    <div class="mt-6 grid gap-5 lg:grid-cols-[0.85fr_1.15fr] lg:items-stretch">
      <div class="rounded-[1.75rem] border border-[var(--color-border)] bg-white/60 p-5">
        <p class="text-[0.72rem] uppercase tracking-[0.22em] text-[var(--color-text-soft)]">{content.addressLabel}</p>
        <div class="mt-3 space-y-1 text-base leading-7 text-[var(--color-text)]">
          {resolvedAddress.map((line) => <p>{line}</p>)}
        </div>
        <p class="mt-4 text-sm leading-6 text-[var(--color-text-soft)]">{content.privacyNotice}</p>
        <div class="mt-5 flex flex-wrap gap-3">
          <Button href={resolvedMapUrl} variant="secondary" target="_blank" rel="noopener noreferrer">
            {content.openMapLabel}
          </Button>
          {canLoadLiveMap && (
            <button
              type="button"
              class="inline-flex min-h-11 items-center justify-center rounded-full border border-[var(--color-secondary)] px-5 py-3 text-sm font-medium text-[var(--color-secondary)] transition hover:bg-[rgba(4,92,180,0.08)]"
              data-map-load
              data-map-embed-url={embedUrl ?? undefined}
            >
              {content.loadMapLabel}
            </button>
          )}
        </div>
      </div>

      <div class="rounded-[1.75rem] border border-dashed border-[var(--color-border-strong)] bg-[linear-gradient(135deg,rgba(4,92,180,0.08),rgba(255,119,0,0.08))] p-5">
        <p class="text-[0.72rem] uppercase tracking-[0.22em] text-[var(--color-text-soft)]">{content.mapConsentTitle}</p>
        <div class="mt-4 rounded-[1.5rem] border border-[var(--color-border)] bg-[var(--color-surface)] p-5">
          <p class="text-base leading-7 text-[var(--color-text-muted)]">{content.mapConsentText}</p>
          <p class="mt-4 text-sm leading-6 text-[var(--color-text-soft)]">{content.fallbackText}</p>
          {canLoadLiveMap ? (
            <div class="mt-5" data-map-live-container hidden></div>
          ) : (
            <div class="mt-5 flex min-h-[16rem] items-end rounded-[1.25rem] border border-[var(--color-border)] bg-[radial-gradient(circle_at_top,rgba(4,92,180,0.14),transparent_45%),linear-gradient(180deg,rgba(255,255,255,0.9),rgba(248,250,252,0.9))] p-5">
              <div class="space-y-2">
                <p class="text-lg font-medium text-[var(--color-text)]">{content.address}</p>
                <p class="text-sm leading-6 text-[var(--color-text-muted)]">{content.privacyNotice}</p>
              </div>
            </div>
          )}
        </div>
      </div>
    </div>
  </Card>
)}
