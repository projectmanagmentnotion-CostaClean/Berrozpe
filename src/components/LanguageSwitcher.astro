---
import type { AlternateLink } from '../lib/content';

interface Props {
  currentLocale: string;
  links: AlternateLink[];
  label: string;
}

const { currentLocale, links, label } = Astro.props;
---

<nav aria-label={label}>
  <ul class="flex flex-wrap items-center gap-2">
    {links.map((link) => {
      const isCurrent = link.locale === currentLocale;

      return (
        <li>
          <a
            aria-current={isCurrent ? 'page' : undefined}
            class:list={[
              'inline-flex min-h-11 items-center rounded-full border px-4 text-[0.74rem] font-medium uppercase tracking-[0.2em] transition focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-accent)] focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--color-bg)]',
              isCurrent
                ? 'border-[var(--color-accent)] bg-[var(--color-accent)] text-[var(--color-ink)]'
                : 'border-[var(--color-border)] text-[var(--color-text-soft)] hover:border-[var(--color-border-strong)] hover:text-[var(--color-text)]',
            ]}
            href={link.href}
            hreflang={link.locale}
            lang={link.locale}
          >
            {link.label}
          </a>
        </li>
      );
    })}
  </ul>
</nav>
