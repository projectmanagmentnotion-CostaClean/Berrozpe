---
import type { AlternateLink } from '../lib/content';

interface Props {
  currentLocale: string;
  links: AlternateLink[];
  label: string;
}

const { currentLocale, links, label } = Astro.props;
---

<nav aria-label={label}>
  <ul class="flex flex-wrap items-center gap-2 text-xs font-semibold uppercase tracking-[0.18em] text-slate-300">
    {links.map((link) => {
      const isCurrent = link.locale === currentLocale;

      return (
        <li>
          <a
            aria-current={isCurrent ? 'page' : undefined}
            class:list={[
              'inline-flex rounded-full border px-3 py-2 transition',
              isCurrent
                ? 'border-cyan-300 bg-cyan-300 text-slate-950'
                : 'border-white/15 text-slate-200 hover:border-white/40 hover:bg-white/5',
            ]}
            href={link.href}
            hreflang={link.locale}
            lang={link.locale}
          >
            {link.label}
          </a>
        </li>
      );
    })}
  </ul>
</nav>
