---
import type { HomeSection } from '../data/types';
import SectionShell from './SectionShell.astro';

interface Props {
  section: HomeSection;
}

const { section } = Astro.props;
---

<SectionShell id={section.sectionId} eyebrow={section.eyebrow} title={section.title} body={section.body}>
  {section.items && section.items.length > 0 && (
    <ul class="mt-10 grid gap-4 md:grid-cols-2">
      {section.items.map((item) => (
        <li class="rounded-3xl border border-white/10 bg-white/5 p-6 text-sm leading-7 text-slate-200">
          {item}
        </li>
      ))}
    </ul>
  )}
</SectionShell>
