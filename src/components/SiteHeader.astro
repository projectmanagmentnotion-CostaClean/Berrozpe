---
import type { AlternateLink, Locale } from '../lib/content';
import { buildWhatsAppUrl, getNavigation, getRouteCatalog, getSiteSettings, getWhatsAppContent } from '../lib/content';
import Button from './Button.astro';
import Container from './Container.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import MobileMenu from './MobileMenu.astro';

interface Props {
  locale: Locale;
  languageLinks: AlternateLink[];
}

const { locale, languageLinks } = Astro.props;
const site = getSiteSettings(locale);
const navigation = getNavigation(locale);
const routes = getRouteCatalog(locale);
const contactLabel = navigation.items.find((item) => item.id === 'contact')?.label ?? 'Contact';
const whatsAppContent = getWhatsAppContent(locale);
const whatsAppHref = buildWhatsAppUrl(locale);
---

<header class="sticky top-0 z-40 border-b border-[var(--color-border)] bg-[color:var(--color-header)] backdrop-blur-xl">
  <Container className="relative">
    <div class="flex min-h-20 items-center justify-between gap-4">
      <a class="flex min-h-11 items-center text-sm font-semibold uppercase tracking-[0.3em] text-[var(--color-text)]" href={site.localeBasePath}>
        {site.brandName}
      </a>

      <nav aria-label="Principal" class="hidden xl:block">
        <ul class="flex items-center gap-7 text-sm text-[var(--color-text-muted)]">
          {navigation.items.filter((item) => item.id !== 'language').map((item) => (
            <li>
              <a class="inline-flex min-h-11 items-center transition hover:text-[var(--color-text)]" href={item.href ?? site.localeBasePath}>
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <div class="hidden items-center gap-3 lg:flex">
        <LanguageSwitcher currentLocale={locale} links={languageLinks} label={navigation.items.find((item) => item.id === 'language')?.label ?? 'Language'} />
        <Button href={whatsAppHref} variant="secondary" target="_blank" rel="noopener noreferrer">
          {whatsAppContent.shortLabel}
        </Button>
        <Button href={routes.contact} variant="primary">
          {contactLabel}
        </Button>
      </div>

      <div class="flex items-center gap-3 lg:hidden">
        <Button href={routes.contact} variant="secondary" className="hidden sm:inline-flex">
          {contactLabel}
        </Button>
        <MobileMenu
          locale={locale}
          navigation={navigation}
          languageLinks={languageLinks}
          contactHref={routes.contact}
          contactLabel={contactLabel}
        />
      </div>
    </div>
  </Container>
</header>
