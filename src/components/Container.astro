---
interface Props {
  as?: keyof HTMLElementTagNameMap;
  size?: 'default' | 'wide' | 'narrow';
  className?: string;
}

const {
  as: Tag = 'div',
  size = 'default',
  className = '',
} = Astro.props;

const sizeClass = {
  default: 'max-w-7xl',
  wide: 'max-w-[92rem]',
  narrow: 'max-w-4xl',
}[size];
---

<Tag class:list={['mx-auto w-full px-5 sm:px-6 lg:px-8', sizeClass, className]}>
  <slot />
</Tag>
