---
import type { Locale } from '../lib/content';
import { getCookieConsentContent, getRouteCatalog } from '../lib/content';
import CookiePreferencesModal from './CookiePreferencesModal.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const cookieConsent = getCookieConsentContent(locale);
const routes = getRouteCatalog(locale);
---

<div
  class="fixed inset-x-0 bottom-0 z-50 p-4"
  data-cookie-consent-root
  data-cookie-storage-key={cookieConsent.storageKey}
  data-cookie-version={cookieConsent.version}
  data-cookie-saved-message={cookieConsent.savedMessage}
>
  <div
    class="mx-auto max-w-5xl rounded-[2rem] border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-5 shadow-[0_30px_100px_rgba(2,6,23,0.24)] sm:p-6"
    data-cookie-banner
  >
    <div class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
      <div class="max-w-3xl space-y-3">
        <p class="text-[0.72rem] uppercase tracking-[0.22em] text-[var(--color-text-soft)]">{cookieConsent.banner.title}</p>
        <p class="text-base leading-8 text-[var(--color-text-muted)]">
          {cookieConsent.banner.body}
          {' '}
          <a class="font-medium text-[var(--color-secondary)] underline-offset-4 hover:underline" href={routes.legal.cookies}>
            {cookieConsent.banner.policyLabel}
          </a>
        </p>
      </div>

      <div class="flex flex-wrap gap-3">
        <button
          type="button"
          class="inline-flex min-h-12 items-center rounded-full border border-transparent bg-[var(--color-accent)] px-6 py-3.5 text-sm font-medium text-[var(--color-ink)] transition hover:bg-[var(--color-accent-soft)]"
          data-cookie-accept
        >
          {cookieConsent.banner.acceptLabel}
        </button>
        <button
          type="button"
          class="inline-flex min-h-12 items-center rounded-full border border-[var(--color-border)] px-6 py-3.5 text-sm font-medium text-[var(--color-text)] transition hover:border-[var(--color-border-strong)]"
          data-cookie-reject
        >
          {cookieConsent.banner.rejectLabel}
        </button>
        <button
          type="button"
          class="inline-flex min-h-12 items-center rounded-full border border-[var(--color-secondary)] px-6 py-3.5 text-sm font-medium text-[var(--color-secondary)] transition hover:bg-[rgba(4,92,180,0.08)]"
          data-cookie-configure
        >
          {cookieConsent.banner.configureLabel}
        </button>
      </div>
    </div>
  </div>

  <div class="sr-only" aria-live="polite" data-cookie-status></div>
</div>

<CookiePreferencesModal content={cookieConsent} />
