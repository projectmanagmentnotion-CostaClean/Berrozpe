---
import { getLegalPages, getSiteSettings } from '../lib/content';

const site = getSiteSettings();
const legalPages = getLegalPages();
---

<footer class="border-t border-white/10 bg-slate-950">
  <div class="mx-auto grid max-w-6xl gap-8 px-6 py-10 md:grid-cols-[1.2fr_0.8fr]">
    <div class="space-y-3">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-white">{site.brandName}</p>
      <p class="max-w-xl text-sm text-slate-300">{site.defaultDescription}</p>
      <div class="text-sm text-slate-400">
        {site.primaryPhone && <p>{site.primaryPhone}</p>}
        {site.primaryEmail && <p>{site.primaryEmail}</p>}
      </div>
    </div>

    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-white">Legal</p>
      <ul class="mt-3 space-y-2 text-sm text-slate-300">
        {legalPages.map((page) => (
          <li>
            <a class="transition hover:text-white" href={`/legal/${page.slug}/`}>{page.title}</a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</footer>
