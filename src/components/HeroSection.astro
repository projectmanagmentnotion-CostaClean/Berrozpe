---
import type { HomeSection } from '../data/types';
import SectionShell from './SectionShell.astro';

interface Props {
  section: HomeSection;
}

const { section } = Astro.props;
---

<SectionShell
  id={section.sectionId}
  eyebrow={section.eyebrow}
  title={section.title}
  body={section.body}
  className="pt-20 md:pt-28"
>
  <div class="mt-10 flex flex-wrap gap-4">
    {section.primaryCtaLabel && section.primaryCtaHref && (
      <a
        class="inline-flex items-center rounded-full bg-cyan-300 px-6 py-3 text-sm font-semibold text-slate-950 transition hover:bg-cyan-200"
        href={section.primaryCtaHref}
      >
        {section.primaryCtaLabel}
      </a>
    )}

    {section.secondaryCtaLabel && section.secondaryCtaHref && (
      <a
        class="inline-flex items-center rounded-full border border-white/15 px-6 py-3 text-sm font-semibold text-white transition hover:border-white/35 hover:bg-white/5"
        href={section.secondaryCtaHref}
      >
        {section.secondaryCtaLabel}
      </a>
    )}
  </div>
</SectionShell>
