---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPublishedServices, getServiceBySlug } from '../../lib/content';

export function getStaticPaths() {
  return getPublishedServices().map((service) => ({
    params: { slug: service.slug },
  }));
}

const { slug } = Astro.params;
const service = slug ? getServiceBySlug(slug) : undefined;

if (!service || service.status !== 'published') {
  throw new Error(`Service not found or unpublished: ${slug}`);
}
---

<BaseLayout title={service.seoTitle} description={service.seoDescription} path={`/servicios/${service.slug}/`}>
  <section class="mx-auto max-w-4xl px-6 py-16 md:py-24" data-animate>
    <p class="text-xs font-semibold uppercase tracking-[0.28em] text-cyan-300">Servicio</p>
    <h1 class="mt-4 text-4xl font-semibold tracking-tight text-white md:text-6xl">{service.heroTitle}</h1>
    <p class="mt-6 text-lg leading-8 text-slate-300">{service.summary}</p>

    <div class="mt-10 space-y-6">
      {service.body.map((paragraph) => (
        <p class="text-base leading-8 text-slate-300">{paragraph}</p>
      ))}
    </div>

    <div class="mt-10 rounded-3xl border border-white/10 bg-white/5 p-6 text-sm leading-7 text-slate-300">
      {service.serviceAreaNote}
    </div>
  </section>
</BaseLayout>
