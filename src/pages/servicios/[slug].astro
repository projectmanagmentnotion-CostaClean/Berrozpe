---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getNavigation, getPublishedServices, getServiceById, getServiceBySlug, getServiceRouteById } from '../../lib/content';

export function getStaticPaths() {
  return getPublishedServices().map((service) => ({
    params: { slug: service.slug },
  }));
}

const { slug } = Astro.params;
const service = slug ? getServiceBySlug(slug) : undefined;
const navigation = getNavigation();

if (!service) {
  throw new Error(`Service not found: ${slug}`);
}
---

<BaseLayout title={service.seoTitle} description={service.seoDescription} path={`/servicios/${service.slug}/`}>
  <section class="mx-auto max-w-4xl px-6 py-16 md:py-24" data-animate>
    <p class="text-xs font-semibold uppercase tracking-[0.28em] text-cyan-300">{navigation.ui.serviceEyebrow}</p>
    <h1 class="mt-4 text-4xl font-semibold tracking-tight text-white md:text-6xl">{service.heroTitle}</h1>
    <p class="mt-6 text-base leading-8 text-slate-300">{service.intro}</p>
    <p class="mt-4 text-lg leading-8 text-slate-300">{service.summary}</p>

    <div class="mt-10 grid gap-8 md:grid-cols-2">
      <section class="space-y-4">
        <h2 class="text-2xl font-semibold text-white">{service.includes.title}</h2>
        <ul class="space-y-2 text-base leading-8 text-slate-300">
          {service.includes.items.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </section>

      <section class="space-y-4">
        <h2 class="text-2xl font-semibold text-white">{service.benefits.title}</h2>
        <ul class="space-y-2 text-base leading-8 text-slate-300">
          {service.benefits.items.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </section>
    </div>

    <section class="mt-10 space-y-4">
      <h2 class="text-2xl font-semibold text-white">{service.process.title}</h2>
      <ul class="space-y-2 text-base leading-8 text-slate-300">
        {service.process.items.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </section>

    <section class="mt-10 space-y-6">
      <h2 class="text-2xl font-semibold text-white">{service.faqs.title}</h2>
      {service.faqs.items.map((item) => (
        <article class="rounded-3xl border border-white/10 bg-white/5 p-6">
          <h3 class="text-lg font-semibold text-white">{item.question}</h3>
          <p class="mt-3 text-base leading-8 text-slate-300">{item.answer}</p>
        </article>
      ))}
    </section>

    <section class="mt-10 space-y-4">
      <h2 class="text-2xl font-semibold text-white">{navigation.ui.relatedServicesTitle}</h2>
      <div class="flex flex-wrap gap-3">
        {service.relatedServices.map((serviceId) => {
          const relatedService = getServiceById(serviceId);
          const route = getServiceRouteById(serviceId);
          return relatedService && route ? (
            <a class="rounded-full border border-white/10 px-4 py-2 text-sm text-slate-200 transition hover:border-cyan-300/50" href={route}>
              {relatedService.shortTitle}
            </a>
          ) : null;
        })}
      </div>
    </section>

    <section class="mt-10 rounded-3xl border border-white/10 bg-white/5 p-6">
      <h2 class="text-xl font-semibold text-white">{navigation.ui.pendingConfirmationLabel}</h2>
      <ul class="mt-4 space-y-2 text-sm leading-7 text-slate-300">
        {service.pendingConfirmation.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
      <div class="mt-6 flex flex-wrap gap-3">
        <a class="inline-flex rounded-full bg-cyan-300 px-5 py-3 text-sm font-semibold text-slate-950" href={service.cta.href}>{service.cta.label}</a>
        <a class="inline-flex rounded-full border border-white/15 px-5 py-3 text-sm font-semibold text-white" href={service.cta.secondaryHref}>{service.cta.secondaryLabel}</a>
      </div>
    </section>
  </section>
</BaseLayout>
