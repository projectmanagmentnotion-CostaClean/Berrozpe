---
import ContactCTA from '../../components/ContactCTA.astro';
import ConversionLinkBlock from '../../components/ConversionLinkBlock.astro';
import FAQSection from '../../components/FAQSection.astro';
import HeroSection from '../../components/HeroSection.astro';
import ProcessSection from '../../components/ProcessSection.astro';
import ReviewsSection from '../../components/ReviewsSection.astro';
import ServicesPreview from '../../components/ServicesPreview.astro';
import WhyChooseUs from '../../components/WhyChooseUs.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  getAllowedLocales,
  getHomeCollection,
  getInternalLinks,
  getInternalLinksContent,
  getLanguageSwitcherLinksForPage,
  getLocalBusinessSchema,
  getOgImagePath,
  getPublishedServices,
  getRouteCatalog,
  getSeoData,
  getSiteSettings,
  isLocale,
  type Locale,
} from '../../lib/content';

export function getStaticPaths() {
  return getAllowedLocales().map((locale) => ({
    params: { locale },
    props: { locale },
  }));
}

const { locale } = Astro.props as { locale: Locale };

if (!isLocale(locale)) {
  throw new Error(`Unsupported locale: ${locale}`);
}

const home = getHomeCollection(locale);
const services = getPublishedServices(locale);
const seo = getSeoData(locale);
const routes = getRouteCatalog(locale);
const site = getSiteSettings(locale);
const internalLinksContent = getInternalLinksContent(locale);
const homeLinks = getInternalLinks(locale, 'home');
const heroHighlights = [
  {
    label: home.servicesOverview.eyebrow,
    value: String(services.length).padStart(2, '0'),
    description: home.servicesOverview.items?.join(' · '),
  },
  {
    label: home.hero.eyebrow,
    value: String(site.supportedLocales.length).padStart(2, '0'),
    description: site.supportedLocales.map((entry) => entry.toUpperCase()).join(' · '),
  },
];
---

<BaseLayout
  locale={locale}
  title={seo.titles.home}
  description={seo.descriptions.home}
  canonicalPath={routes.home}
  alternates={getLanguageSwitcherLinksForPage('home')}
  ogImagePath={getOgImagePath('default')}
  schema={getLocalBusinessSchema(locale, { path: routes.home, includeAggregateRating: true })}
>
  <HeroSection section={home.hero} highlights={heroHighlights} />
  <ServicesPreview locale={locale} section={home.servicesOverview} services={services} />
  <ConversionLinkBlock
    locale={locale}
    eyebrow={internalLinksContent.home.eyebrow}
    title={internalLinksContent.home.title}
    body={internalLinksContent.home.body}
    number="02"
    links={[
      ...(homeLinks.services ?? []).map((service) => ({
        label: service.shortTitle,
        href: routes.servicesById[service.serviceId],
        description: internalLinksContent.home.serviceListTitle,
        variant: 'secondary' as const,
      })),
      {
        label: internalLinksContent.home.trustLabel,
        href: homeLinks.trustPath,
        variant: 'ghost' as const,
      },
      {
        label: internalLinksContent.home.contactLabel,
        href: homeLinks.contactPath,
        variant: 'primary' as const,
      },
    ]}
  />
  <ProcessSection section={home.process} number="03" />
  <WhyChooseUs section={home.whyChooseUs} number="04" />
  <ReviewsSection locale={locale} number="05" />
  <ContactCTA locale={locale} section={home.contactCta} />
  <FAQSection section={home.faqs} number="06" />
</BaseLayout>
