---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLegalPage, getLegalPages } from '../../lib/content';

export function getStaticPaths() {
  return getLegalPages().map((page) => ({
    params: { slug: page.slug },
  }));
}

const { slug } = Astro.params;
const page = slug ? getLegalPage(slug) : undefined;

if (!page) {
  throw new Error(`Legal page not found: ${slug}`);
}
---

<BaseLayout title={`${page.title} | Instal Berrozpe`} description={page.intro} path={`/legal/${page.slug}/`}>
  <section class="mx-auto max-w-4xl px-6 py-16 md:py-24" data-animate>
    <p class="text-xs font-semibold uppercase tracking-[0.28em] text-cyan-300">Legal</p>
    <h1 class="mt-4 text-4xl font-semibold tracking-tight text-white md:text-6xl">{page.title}</h1>
    <p class="mt-6 text-base leading-8 text-slate-300">{page.intro}</p>
    <p class="mt-4 text-sm text-slate-400">Ultima actualizacion declarada: {page.updatedAt}</p>

    <div class="mt-10 space-y-10">
      {page.sections.map((section) => (
        <section class="space-y-4">
          <h2 class="text-2xl font-semibold text-white">{section.heading}</h2>
          {section.body.map((paragraph) => (
            <p class="text-base leading-8 text-slate-300">{paragraph}</p>
          ))}
        </section>
      ))}
    </div>
  </section>
</BaseLayout>
